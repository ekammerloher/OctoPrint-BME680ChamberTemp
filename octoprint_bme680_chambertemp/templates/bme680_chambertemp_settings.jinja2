<div id="settings_plugin_bme680_chambertemp" class="form-horizontal">
  <div class="control-group">
    <label class="control-label">I2C address</label>
    <div class="controls">
      <select data-bind="value: settings.plugins.bme680_chambertemp.i2c_address">
        <option value="0x76">0x76</option>
        <option value="0x77">0x77</option>
        <option value="auto">auto</option>
      </select>
      <p class="help-block">Auto mode tries 0x76 first, then 0x77.</p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label">I2C bus</label>
    <div class="controls">
      <input type="number" min="0" data-bind="value: settings.plugins.bme680_chambertemp.i2c_bus">
    </div>
  </div>

  <div class="control-group">
    <label class="control-label">Polling interval</label>
    <div class="controls">
      <input type="number" min="1" step="1" data-bind="value: settings.plugins.bme680_chambertemp.poll_interval">
      <span>seconds</span>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label">Temperature offset</label>
    <div class="controls">
      <input type="number" step="0.1" data-bind="value: settings.plugins.bme680_chambertemp.temperature_offset">
      <span>&deg;C</span>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label">Inject chamber temperature</label>
    <div class="controls">
      <label class="checkbox">
        <input type="checkbox" data-bind="checked: settings.plugins.bme680_chambertemp.inject_temperature">
        Add chamber temperature to OctoPrint's default temperature graph
      </label>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label">Injected temperature name</label>
    <div class="controls">
      <input type="text" data-bind="value: settings.plugins.bme680_chambertemp.temperature_name" placeholder="chamber">
      <p class="help-block">Used as the temperature key in OctoPrint's default graph, for example <code>chamber</code>.</p>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label">Show plugin tab</label>
    <div class="controls">
      <label class="checkbox">
        <input type="checkbox" data-bind="checked: settings.plugins.bme680_chambertemp.show_tab">
        Show the dedicated BME680 tab
      </label>
    </div>
  </div>

  <div class="control-group">
    <label class="control-label">Logging verbosity</label>
    <div class="controls">
      <select data-bind="value: settings.plugins.bme680_chambertemp.logging_verbosity">
        <option value="normal">Normal</option>
        <option value="debug">Debug</option>
      </select>
    </div>
  </div>

  <hr>
  <h4>Diagnostics</h4>
  <p><strong>Status:</strong> <span id="bme680_chambertemp_settings_status" data-bind="text: statusText">Initializing</span></p>
  <p><strong>Last successful reading:</strong> <span id="bme680_chambertemp_settings_last_success" data-bind="text: lastSuccessText">--</span></p>
  <p><strong>Last error:</strong> <span id="bme680_chambertemp_settings_last_error" data-bind="text: lastErrorText">--</span></p>
  <p><strong>Configured bus/address:</strong> <span id="bme680_chambertemp_settings_configured_bus" data-bind="text: configuredBus">--</span> / <span id="bme680_chambertemp_settings_configured_address" data-bind="text: configuredAddress">--</span></p>
  <p><strong>Active address:</strong> <span id="bme680_chambertemp_settings_active_address" data-bind="text: activeAddress">--</span></p>
  <p><strong>Injected temperature name:</strong> <span id="bme680_chambertemp_settings_temperature_name" data-bind="text: temperatureName">chamber</span></p>
  <p><strong>Versions:</strong> plugin <span id="bme680_chambertemp_settings_plugin_version" data-bind="text: pluginVersion">--</span>, library <span id="bme680_chambertemp_settings_library_version" data-bind="text: libraryVersion">--</span></p>
</div>
