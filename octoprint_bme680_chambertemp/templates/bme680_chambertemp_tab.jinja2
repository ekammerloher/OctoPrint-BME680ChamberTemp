<div class="bme680-chambertemp">
  <div class="bme680-chambertemp__header">
    <h2>BME680 Chamber Environment</h2>
    <p>
      Status: <strong data-bind="text: statusText"></strong>
      <!-- ko if: lastError -->
      <span class="bme680-chambertemp__warning" data-bind="text: lastError"></span>
      <!-- /ko -->
    </p>
  </div>

  <div class="bme680-chambertemp__grid">
    <div class="bme680-chambertemp__card">
      <span class="bme680-chambertemp__label">Temperature</span>
      <span class="bme680-chambertemp__value" data-bind="text: temperatureText"></span> <span>&deg;C</span>
    </div>
    <div class="bme680-chambertemp__card">
      <span class="bme680-chambertemp__label">Relative humidity</span>
      <span class="bme680-chambertemp__value" data-bind="text: humidityText"></span> <span>%</span>
    </div>
    <div class="bme680-chambertemp__card">
      <span class="bme680-chambertemp__label">Gas resistance</span>
      <span class="bme680-chambertemp__value" data-bind="text: gasResistanceText"></span> <span>&Omega;</span>
    </div>
  </div>

  <div class="bme680-chambertemp__meta">
    <div class="bme680-chambertemp__meta-item">
      <strong>Last update:</strong> <span data-bind="text: lastUpdateText"></span>
    </div>
    <div class="bme680-chambertemp__meta-item">
      <strong>Last successful reading:</strong> <span data-bind="text: lastSuccessText"></span>
    </div>
    <div class="bme680-chambertemp__meta-item">
      <strong>Configured bus/address:</strong>
      <span data-bind="text: configuredBus"></span> /
      <span data-bind="text: configuredAddress"></span>
    </div>
    <div class="bme680-chambertemp__meta-item">
      <strong>Active address:</strong> <span data-bind="text: activeAddress"></span>
    </div>
    <div class="bme680-chambertemp__meta-item">
      <strong>Plugin version:</strong> <span data-bind="text: pluginVersion"></span>
    </div>
    <div class="bme680-chambertemp__meta-item">
      <strong>Adafruit library version:</strong> <span data-bind="text: libraryVersion"></span>
    </div>
  </div>
</div>
